# Copy to /etc/jellyrpc.env and `chmod 600` it.
DISCORD_TOKEN=
JELLYFIN_URL=https://jellyfin.example.com
JELLYFIN_API_KEY=
JELLYFIN_USER_ID=

# Required for artwork to show (see README "Getting artwork to show up")
DISCORD_APP_ID=

# Optional
# auto (default) detects a private JELLYFIN_URL and rehosts artwork via
# litterbox.catbox.moe automatically. Set to "rehost" or "direct" to force.
ARTWORK_MODE=auto
POLL_INTERVAL_SECONDS=15
IDLE_TIMEOUT_SECONDS=60
